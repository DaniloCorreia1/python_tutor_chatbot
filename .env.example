# ============================================================
# CONFIGURAÇÕES DE AMBIENTE — Python Tutor Chatbot
# ============================================================
# Copie este arquivo para .env e preencha com suas chaves reais


# ---------------------------
# OpenAI — obrigatório
# Obtenha em: https://platform.openai.com/api-keys
# ---------------------------
OPENAI_API_KEY=Insira-sua-chave-openai-válida-aqui


# ---------------------------
# LangSmith — opcional (monitoramento e rastreamento)
# Obtenha em: https://smith.langchain.com
# ---------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-sua-chave-aqui
LANGCHAIN_PROJECT=python-tutor-chatbot

# ---------------------------
# Django
# ---------------------------
DJANGO_SECRET_KEY=troque-por-uma-chave-segura-em-producao
DJANGO_DEBUG=True
